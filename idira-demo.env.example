# Copy to idira-demo.env and fill in. That filename is gitignored.
#
# The Makefile sources this file before every target that talks to the tenant,
# so `make up` works in a fresh shell with nothing exported.
#
# ALWAYS single-quote the values. Service tokens routinely contain characters
# like ) + < > ? that the shell will otherwise try to interpret, and the failure
# looks like "parse error" rather than anything credential-related.

export IDSEC_SERVICE_USER='svc-terraform@cyberark.cloud.NNNNN'
export IDSEC_SERVICE_TOKEN='your-service-user-secret'

# Only if your tenant uses a custom OAuth app rather than the default.
# export IDSEC_SERVICE_AUTHORIZED_APP='__idaptive_cybr_user_oidc'
