# Copy to terraform.tfvars and fill in. Credentials do NOT go here -- they are
# read from the environment (see README "Before you present").

# Required: your Idira tenant subdomain, e.g. "acme" for acme.cyberark.cloud.
idsec_subdomain = "CHANGEME"

aws_region = "us-east-2"
demo_name  = "idira-sia-demo"

# Optional. Leave unset to auto-detect your public IP for the connector install.
# Set it explicitly if you are behind a VPN with a stable egress range.
# admin_cidr = "203.0.113.4/32"

# Optional but recommended before a live demo: pin the SSH CA public key so the
# plan does not depend on a live API call. Fetch it once with:
#   ./scripts/get-sia-ssh-ca.py | python3 -c 'import json,sys;print(json.load(sys.stdin)["public_key"])'
# sia_ssh_ca_public_key = "ssh-rsa AAAAB3Nza..."

# The Idira role granted access to the target. Resolved to a role ID at plan time
# by the idsec_identity_role data source, so no opaque IDs in the config.
#
# You must be a member of this role or the connect step will fail on stage.
policy_role_name = "Demo Admins"

# How the policy identifies the target: "aws" (match by VPC + Role tag, via cloud
# discovery) or "fqdnip" (match the private IP directly). Flip to "fqdnip" if AWS
# discovery does not resolve the instance during a live run.
# policy_target_mode = "aws"

# Only needed for multiple principals, or USER/GROUP types (which also require
# source_directory_id and source_directory_name). Overrides policy_role_name.
# policy_principals = [{
#   id   = "your_role_id_here"
#   name = "Some Group"
#   type = "GROUP"
#   source_directory_id   = "..."
#   source_directory_name = "..."
# }]
